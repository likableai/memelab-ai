# Server
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/suban_ai

# BSC (BNB Smart Chain) - replace SOLANA_* with these
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_CHAIN_ID=56
TOKEN_CONTRACT_ADDRESS=<YOUR_BEP20_TOKEN_ADDRESS>
TREASURY_WALLET_ADDRESS=<YOUR_TREASURY_WALLET_ADDRESS>
BACKEND_WALLET_PRIVATE_KEY=<EVM_PRIVATE_KEY_HEX_OR_0x_PREFIXED>

# Deprecated (Solana) - remove after migration
# SOLANA_RPC_URL=
# TOKEN_MINT_ADDRESS=

# AI API Keys
DEEPSEEK_API_KEY=
GROK_API_KEY=

# Token Price (BSC) - e.g. CoinGecko or DEX API
COINGECKO_API_URL=https://api.coingecko.com/api/v3
TOKEN_COINGECKO_ID=

# Tokenomics
BURN_FLOOR=0.05
BURN_CEILING=50
TWAP_WINDOW_MINUTES=10

# Cost
DEFAULT_CHAT_COST_USD=0.02
DEFAULT_VOICE_COST_USD=0.10

# Admin
ADMIN_WALLET_ADDRESSES=
